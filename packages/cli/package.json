{
  "name": "@lingui/cli",
  "version": "6.3.0",
  "description": "Lingui CLI to extract messages, compile catalogs, and manage translation workflows",
  "type": "module",
  "keywords": [
    "lingui",
    "linguijs",
    "cli",
    "i18n",
    "extract",
    "compile",
    "catalog",
    "gettext",
    "translation",
    "localization"
  ],
  "homepage": "https://lingui.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lingui/js-lingui.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/lingui/js-lingui/issues",
  "license": "MIT",
  "author": {
    "name": "Tomáš Ehrlich",
    "email": "tomas.ehrlich@gmail.com"
  },
  "bin": {
    "lingui": "./dist/lingui.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api/index.js",
    "./api/extractors/babel": "./dist/api/extractors/babel.js",
    "./bundlers/esbuild": "./dist/extract-experimental/bundlers/esbuild.js",
    "./bundlers/rolldown": "./dist/extract-experimental/bundlers/rolldown.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/"
  ],
  "dependencies": {
    "@babel/core": "^7.21.0",
    "@babel/generator": "^7.28.5",
    "@babel/parser": "^7.22.0",
    "@babel/types": "^7.21.2",
    "@lingui/babel-plugin-extract-messages": "workspace:*",
    "@lingui/babel-plugin-lingui-macro": "workspace:*",
    "@lingui/conf": "workspace:*",
    "@lingui/core": "workspace:*",
    "@lingui/format-po": "workspace:*",
    "@lingui/message-utils": "workspace:*",
    "chokidar": "5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "jiti": "^2.6.1",
    "micromatch": "^4.0.7",
    "ms": "^2.1.3",
    "normalize-path": "^3.0.0",
    "ora": "^9.1.0",
    "pseudolocale": "^2.2.0",
    "source-map": "^0.7.6",
    "tinypool": "^2.1.0"
  },
  "peerDependencies": {
    "@rolldown/plugin-babel": ">=0.1.0",
    "esbuild": "^0.28.0",
    "rolldown": "^1.1.0"
  },
  "peerDependenciesMeta": {
    "@rolldown/plugin-babel": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lingui/test-utils": "workspace:*",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__generator": "^7.27.0",
    "@types/micromatch": "^4.0.1",
    "@types/ms": "^2.1.0",
    "@types/normalize-path": "^3.0.0",
    "esbuild": "^0.28.0",
    "mock-fs": "^5.2.0",
    "msw": "^2.12.7",
    "rolldown": "^1.1.1",
    "vitest": "catalog:"
  }
}
