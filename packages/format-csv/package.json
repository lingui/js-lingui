{
  "name": "@lingui/format-csv",
  "version": "6.0.0",
  "description": "CSV formatter for Lingui message catalogs",
  "type": "module",
  "exports": {
    ".": "./dist/csv.mjs"
  },
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "lingui",
