exports[`lingui-set directive: useLingui > useLingui t with directive applied per-reference 1`] = `
import { useLingui } from "@lingui/react/macro";
function App() {
  const { t } = useLingui();
  /* lingui-set context="first" */
  const msg1 = t\`Hello\`;
  /* lingui-set context="second" */
  const msg2 = t\`World\`;
  return msg1 + msg2;
}

↓ ↓ ↓ ↓ ↓ ↓

import { useLingui as _useLingui } from "@lingui/react";
function App() {
  const { _: _t } = _useLingui();
  /* lingui-set context="first" */
  const msg1 = _t(
    /*i18n*/
    {
      id: "VUeJYD",
      message: "Hello",
      context: "first",
    },
  );
  /* lingui-set context="second" */
  const msg2 = _t(
    /*i18n*/
    {
      id: "ovKD_8",
      message: "World",
      context: "second",
    },
  );
  return msg1 + msg2;
}

`;

