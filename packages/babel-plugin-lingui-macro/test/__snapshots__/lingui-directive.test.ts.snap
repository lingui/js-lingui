// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`lingui-set directive: JS macros > closest directive takes precedence 1`] = `
import { t } from "@lingui/core/macro";
/* lingui-set context="first" */
const msg1 = t\`Hello\`;
/* lingui-set context="second" */
const msg2 = t\`World\`;

↓ ↓ ↓ ↓ ↓ ↓

/* lingui-set context="first" */ import { i18n as _i18n } from "@lingui/core";
const msg1 = _i18n._(
  /*i18n*/
  {
    id: "VUeJYD",
    message: "Hello",
    context: "first",
  },
);
/* lingui-set context="second" */
const msg2 = _i18n._(
  /*i18n*/
  {
    id: "ovKD_8",
    message: "World",
    context: "second",
  },
);

`;

