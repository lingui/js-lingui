{
  "name": "@lingui/message-utils",
  "version": "6.0.1",
  "description": "Low-level Lingui utilities to compile ICU MessageFormat messages and generate stable message IDs",
  "license": "MIT",
  "keywords": [
    "lingui",
    "messageformat",
    "icu",
    "i18n",
    "compile",
    "message-id",
    "catalog",
    "javascript"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./generateMessageId": {
      "node": "./dist/generateMessageId.node.mjs",
      "default": "./dist/generateMessageId.mjs"
    },
    "./compileMessage": "./dist/compileMessage.mjs"
  },
  "scripts": {
    "build": "unbuild",
    "check-types": "tsc --noEmit"
  },
  "homepage": "https://lingui.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lingui/js-lingui.git",
    "directory": "packages/message-utils"
  },
  "bugs": {
    "url": "https://github.com/lingui/js-lingui/issues"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "README.md",
    "dist/"
  ],
  "dependencies": {
    "@messageformat/date-skeleton": "^1.1.0",
    "@messageformat/parser": "^5.0.0",
    "js-sha256": "^0.10.1"
  },
  "devDependencies": {
    "@lingui/test-utils": "workspace:*",
    "unbuild": "catalog:",
    "vitest": "catalog:"
  },
  "unbuild": {
    "declaration": "node16"
  }
}
