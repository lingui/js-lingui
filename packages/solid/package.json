{
  "name": "@lingui/solid",
  "version": "6.0.0-next.3",
  "sideEffects": false,
  "description": "SolidJS bindings for Lingui with Trans components, providers, and compile-time macros",
  "type": "module",
  "author": {
    "name": "Huliiiiii",
    "email": "huliiiiii.nya@gmail.com"
  },
  "license": "MIT",
  "keywords": [
    "lingui",
    "linguijs",
    "solid",
    "solidjs",
    "i18n",
    "icu",
    "messageformat",
    "localization",
    "translation"
  ],
  "scripts": {
    "build": "unbuild",
    "check-types": "tsc --noEmit",
    "test": "vitest --run"
  },
  "homepage": "https://lingui.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lingui/js-lingui.git",
    "directory": "packages/solid"
  },
  "bugs": {
    "url": "https://github.com/lingui/js-lingui/issues"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "default": "./dist/config.mjs"
    },
    "./macro": {
      "browser": "./macro/browser.mjs",
      "types": "./macro/index.d.mts",
      "default": "./macro/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/",
    "macro/browser.mjs",
    "macro/index.d.mts",
    "macro/index.mjs"
  ],
  "peerDependencies": {
    "babel-plugin-macros": "2 || 3",
    "solid-js": "^1.8.0 || ^1.9.0"
  },
  "peerDependenciesMeta": {
    "babel-plugin-macros": {
      "optional": true
    }
  },
  "dependencies": {
    "@lingui/babel-plugin-lingui-macro": "workspace:*",
    "@lingui/conf": "workspace:*",
    "@lingui/core": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@lingui/test-utils": "workspace:*",
    "@rollup/plugin-babel": "7.0.0",
    "@solidjs/testing-library": "^0.8.10",
    "babel-preset-solid": "1.9.12",
    "eslint": "^9.39.3",
    "happy-dom": "^20.0.10",
    "solid-js": "^1.9.5",
    "unbuild": "3.6.1",
    "vite": "7.3.1",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "4.0.18"
  }
}
